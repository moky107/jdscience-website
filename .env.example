# =============================================================================
# JD Science — Environment Variables
# =============================================================================
# Copy this file to `.env` for local development, and set the SAME variables in
# your Vercel project: Settings -> Environment Variables (Production + Preview).
#
# IMPORTANT: After adding or changing any variable in Vercel you MUST trigger a
# new deployment (Deployments -> Redeploy). Existing deployments do NOT pick up
# env var changes automatically — this is the most common cause of the Stripe
# "You did not provide an API key" error.
# =============================================================================

# --- Stripe (server-side, used by /api serverless functions) ---
# Secret key from https://dashboard.stripe.com/apikeys  (starts with sk_test_ / sk_live_)
STRIPE_SECRET_KEY=

# Signing secret for your webhook endpoint (starts with whsec_)
# Get it from Stripe -> Developers -> Webhooks -> your endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=

# --- Site URL (used to build Stripe success/cancel redirect URLs) ---
# e.g. https://jdscience.co.uk  (no trailing slash)
# Optional: if omitted, the checkout function falls back to the request host.
SITE_URL=

# --- Supabase (server-side, used by /api/webhook.js to insert bookings) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Service role key (SECRET — server only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# --- Frontend (Vite) — OPTIONAL overrides ---
# The public Supabase URL + anon key are safe to expose in the browser.
# These are optional: sensible defaults are hard-coded in src/supabaseClient.js.
# If set, they override the defaults. Vite requires the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
